# ─── LLM endpoint ─────────────────────────────────────────────────────────────
# URL of your OpenAI-compatible LLM server (llama.cpp, vLLM, LM Studio, etc.)
MEWMO_LLM_BASE_URL=http://127.0.0.1:8081/v1

# API token required by vLLM and hosted endpoints.
# For local llama.cpp with no auth, leave as "local" or any non-empty string.
MEWMO_LLM_API_KEY=local

# Model name as reported by your server (must match exactly).
MEWMO_LLM_MODEL=qwen3.5-8b

# Request timeout in seconds. Increase for slow hardware or long audio files.
MEWMO_LLM_TIMEOUT=120

# ─── Storage ──────────────────────────────────────────────────────────────────
# Where to store the file vault, vector DB, and conflicts log.
# Use an absolute path for production; relative paths are resolved from cwd.
MEWMO_DATA_DIR=./data

# ─── Conflict detection ───────────────────────────────────────────────────────
# Cosine distance threshold for triggering a conflict check (0.0–1.0).
# Lower = stricter (more conflicts flagged). Default 0.25 is a good starting point.
MEWMO_CONFLICT_THRESHOLD=0.25
